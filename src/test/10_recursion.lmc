# Test recursion for named functions
# Uses thunks (|>_. expr) to delay branch evaluation (Church encoding approach)

# Factorial function
~factorial n (
    (eq n 0 (|>_. 1) (|>_. n * factorial (n - 1))) 0
)

# Fibonacci function
~fibonacci n (
    (eq n 0 (|>_. 0) (|>_. (eq n 1 (|>_. 1) (|>_. fibonacci (n - 1) + fibonacci (n - 2))) 0)) 0
)

# Sum from 1 to n
~sum n (
    (eq n 0 (|>_. 0) (|>_. n + sum (n - 1))) 0
)

~(
    print (factorial 0)
    print (factorial 1)
    print (factorial 5)
    print (factorial 10)

    print (fibonacci 0)
    print (fibonacci 1)
    print (fibonacci 7)

    print (sum 10)
)
