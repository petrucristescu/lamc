# Test recursion for named functions

# Factorial function
~factorial n (
    eq n 0
        1
        (n * factorial (n - 1))
)

# Fibonacci function
~fibonacci n (
    eq n 0
        0
        (eq n 1
            1
            (fibonacci (n - 1) + fibonacci (n - 2)))
)

# Countdown function
~countdown n (
    eq n 0
        (print 0)
        (print n
         countdown (n - 1))
)

# Sum from 1 to n
~sum n (
    eq n 0
        0
        (n + sum (n - 1))
)

~(
    print (factorial 0)
    print (factorial 1)
    print (factorial 5)
    print (factorial 10)

    print (fibonacci 0)
    print (fibonacci 1)
    print (fibonacci 7)

    countdown 5

    print (sum 10)
)